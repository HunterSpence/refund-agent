# ── Required: the LLM ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=         # required for the live UI, voice input/output, live eval, and deploy
LLM_PROVIDER=anthropic     # optional: "anthropic" (default) | "openai"
LLM_MODEL=                 # optional: model id override (default: claude-sonnet-4-6)

# ── Optional: voice production upgrade (Web Speech API is the keyless default) ──
DEEPGRAM_API_KEY=          # optional: enables /api/deepgram-token (Deepgram Nova-2 STT upgrade)
CARTESIA_API_KEY=          # optional: enables /api/cartesia-token (Cartesia Sonic TTS upgrade)

# ── Optional: Langfuse observability (complete no-op when absent) ────────────────
LANGFUSE_PUBLIC_KEY=       # set both keys to activate OTel tracing in orchestrate.ts
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=          # optional: self-hosted Langfuse host (defaults to cloud)
